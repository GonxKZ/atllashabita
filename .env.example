# Variables de entorno de AtlasHabita. Copia este fichero a `.env` para
# personalizar la configuración local. Todos los nombres van con el prefijo
# ATLASHABITA_ para aislarlos del resto del entorno.

ATLASHABITA_ENV=development
ATLASHABITA_APP_NAME=AtlasHabita API
ATLASHABITA_APP_VERSION=0.1.0

# Orígenes CORS aceptados (JSON array)
ATLASHABITA_CORS_ALLOW_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Carpetas de datos (rutas absolutas o relativas al repo)
# ATLASHABITA_DATA_ROOT=/ruta/a/data
# ATLASHABITA_ONTOLOGY_ROOT=/ruta/a/ontology

# Versión de scoring visible al cliente
ATLASHABITA_SCORING_VERSION=2026.04.1

# Grafo RDF
ATLASHABITA_RDF_GRAPH_BASE_URI=https://data.atlashabita.example/

# Límites y protecciones SPARQL
ATLASHABITA_SPARQL_MAX_RESULTS=500
ATLASHABITA_SPARQL_TIMEOUT_SECONDS=5
ATLASHABITA_SPARQL_ALLOW_UPDATE=false

# Cache
ATLASHABITA_CACHE_TTL_SECONDS=300
ATLASHABITA_CACHE_MAX_ENTRIES=256
