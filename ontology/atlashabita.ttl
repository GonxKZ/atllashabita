@prefix ah:    <https://data.atlashabita.example/ontology/> .
@prefix ahr:   <https://data.atlashabita.example/resource/> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix geo:   <http://www.opengis.net/ont/geosparql#> .
@prefix sf:    <http://www.opengis.net/ont/sf#> .
@prefix wgs84: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix qb:    <http://purl.org/linked-data/cube#> .
@prefix sosa:  <http://www.w3.org/ns/sosa/> .
@prefix ssn:   <http://www.w3.org/ns/ssn/> .

###############################################################################
# Ontología AtlasHabita (v0.3.0 — Fase B M11)                                #
# Amplía v0.2.0 con clases para flujos de movilidad, accidentes y transporte #
# público (MITMA + DGT + CRTM), alineadas con SOSA/SSN y QB.                 #
###############################################################################

<https://data.atlashabita.example/ontology/>
    a owl:Ontology ;
    dct:title "Ontología AtlasHabita"@es ;
    dct:description
        "Vocabulario para representar territorios españoles, indicadores, observaciones, fuentes, scores explicables, geometrías GeoSPARQL, procedencia PROV-O, flujos de movilidad, accidentes viales y red de transporte público."@es ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo "0.3.0" ;
    owl:imports <http://www.opengis.net/ont/geosparql> ,
                <http://www.w3.org/ns/prov-o> ,
                <http://www.w3.org/ns/sosa/> ,
                <http://www.w3.org/ns/ssn/> ,
                <http://purl.org/linked-data/cube> .

###############################################################################
# Jerarquía territorial (alineada con geo:Feature de GeoSPARQL)              #
###############################################################################

ah:Territory
    a owl:Class ;
    rdfs:label "Territorio"@es ;
    rdfs:comment "Entidad territorial administrativa con identidad y geometría."@es ;
    rdfs:subClassOf geo:Feature .

ah:AutonomousCommunity
    a owl:Class ;
    rdfs:label "Comunidad autónoma"@es ;
    rdfs:subClassOf ah:Territory .

ah:Province
    a owl:Class ;
    rdfs:label "Provincia"@es ;
    rdfs:subClassOf ah:Territory .

ah:Municipality
    a owl:Class ;
    rdfs:label "Municipio"@es ;
    rdfs:subClassOf ah:Territory , geo:Feature .

ah:belongsTo
    a owl:ObjectProperty ;
    rdfs:label "pertenece a"@es ;
    rdfs:domain ah:Territory ;
    rdfs:range ah:Territory .

ah:population
    a owl:DatatypeProperty ;
    rdfs:label "población"@es ;
    rdfs:domain ah:Territory ;
    rdfs:range xsd:integer .

ah:area
    a owl:DatatypeProperty ;
    rdfs:label "área (km²)"@es ;
    rdfs:domain ah:Territory ;
    rdfs:range xsd:decimal .

###############################################################################
# Geometrías GeoSPARQL                                                       #
# `ah:hasGeometry` es subpropiedad de `geo:hasGeometry` y `ah:wktLiteral` es #
# subpropiedad de `geo:asWKT`. Permiten serializar puntos (centroides) y,   #
# cuando se disponga de cartografía, polígonos administrativos completos.   #
###############################################################################

ah:hasGeometry
    a owl:ObjectProperty ;
    rdfs:label "geometría"@es ;
    rdfs:comment "Relaciona un territorio (geo:Feature) con su geometría."@es ;
    rdfs:subPropertyOf geo:hasGeometry ;
    rdfs:domain ah:Territory ;
    rdfs:range geo:Geometry .

ah:wktLiteral
    a owl:DatatypeProperty ;
    rdfs:label "WKT"@es ;
    rdfs:comment "Serialización WKT de una geometría (CRS por defecto CRS84)."@es ;
    rdfs:subPropertyOf geo:asWKT ;
    rdfs:domain geo:Geometry ;
    rdfs:range geo:wktLiteral .

###############################################################################
# Indicadores y observaciones                                                #
###############################################################################

ah:Indicator
    a owl:Class ;
    rdfs:label "Indicador"@es ;
    rdfs:comment "Definición semántica de un indicador territorial."@es .

ah:IndicatorObservation
    a owl:Class ;
    rdfs:label "Observación"@es ;
    rdfs:comment "Valor observado de un indicador para un territorio y un periodo."@es ;
    rdfs:subClassOf prov:Entity .

ah:hasIndicatorObservation
    a owl:ObjectProperty ;
    rdfs:label "tiene observación"@es ;
    rdfs:domain ah:Territory ;
    rdfs:range ah:IndicatorObservation .

ah:indicator
    a owl:ObjectProperty ;
    rdfs:label "indicador"@es ;
    rdfs:domain ah:IndicatorObservation ;
    rdfs:range ah:Indicator .

ah:value
    a owl:DatatypeProperty ;
    rdfs:label "valor"@es ;
    rdfs:domain ah:IndicatorObservation ;
    rdfs:range xsd:decimal .

ah:unit
    a owl:DatatypeProperty ;
    rdfs:label "unidad"@es ;
    rdfs:domain ah:IndicatorObservation ;
    rdfs:range xsd:string .

ah:period
    a owl:DatatypeProperty ;
    rdfs:label "periodo"@es ;
    rdfs:domain ah:IndicatorObservation ;
    rdfs:range xsd:string ;
    rdfs:comment "Identificador textual del periodo. Para anios se recomienda usar `ah:periodYear`."@es .

ah:periodYear
    a owl:DatatypeProperty ;
    rdfs:label "año del periodo"@es ;
    rdfs:comment "Periodo tipado como xsd:gYear para consultas temporales nativas."@es ;
    rdfs:domain ah:IndicatorObservation ;
    rdfs:range xsd:gYear .

ah:direction
    a owl:DatatypeProperty ;
    rdfs:label "direccionalidad"@es ;
    rdfs:domain ah:Indicator ;
    rdfs:range xsd:string ;
    rdfs:comment "'higher_is_better' o 'lower_is_better'."@es .

ah:qualityFlag
    a owl:DatatypeProperty ;
    rdfs:label "estado de calidad"@es ;
    rdfs:domain ah:IndicatorObservation ;
    rdfs:range xsd:string .

###############################################################################
# Clase auxiliar ah:Period (xsd:gYear)                                       #
###############################################################################

ah:Period
    a owl:Class ;
    rdfs:label "Periodo"@es ;
    rdfs:comment "Representación mínima de un periodo anual (xsd:gYear)."@es ;
    owl:equivalentClass [
        a owl:Restriction ;
        owl:onProperty ah:periodYear ;
        owl:someValuesFrom xsd:gYear
    ] .

###############################################################################
# Fuentes y procedencia (alineado con PROV-O)                                #
###############################################################################

ah:DataSource
    a owl:Class ;
    rdfs:label "Fuente de datos"@es ;
    rdfs:subClassOf prov:Agent , prov:Entity .

ah:providedBy
    a owl:ObjectProperty ;
    rdfs:label "provista por"@es ;
    rdfs:subPropertyOf prov:wasAttributedTo ;
    rdfs:domain ah:IndicatorObservation ;
    rdfs:range ah:DataSource .

ah:license
    a owl:DatatypeProperty ;
    rdfs:label "licencia"@es ;
    rdfs:domain ah:DataSource ;
    rdfs:range xsd:string .

ah:periodicity
    a owl:DatatypeProperty ;
    rdfs:label "periodicidad"@es ;
    rdfs:domain ah:DataSource ;
    rdfs:range xsd:string .

###############################################################################
# Procedencia detallada: actividad de ingesta (PROV-O)                       #
# Cada observación del grafo puede trazarse a una actividad de ingesta       #
# concreta, que a su vez registra la fuente usada y la observación producida.#
###############################################################################

ah:IngestionActivity
    a owl:Class ;
    rdfs:label "Actividad de ingesta"@es ;
    rdfs:comment "Actividad PROV-O que captura una ejecución concreta de ingesta."@es ;
    rdfs:subClassOf prov:Activity .

ah:ingestedFrom
    a owl:ObjectProperty ;
    rdfs:label "ingerido desde"@es ;
    rdfs:comment "Fuente consumida durante la actividad (subPropertyOf prov:used)."@es ;
    rdfs:subPropertyOf prov:used ;
    rdfs:domain ah:IngestionActivity ;
    rdfs:range ah:DataSource .

ah:produced
    a owl:ObjectProperty ;
    rdfs:label "producido por"@es ;
    rdfs:comment "Observación generada por la actividad (subPropertyOf prov:wasGeneratedBy inverso)."@es ;
    rdfs:domain ah:IngestionActivity ;
    rdfs:range ah:IndicatorObservation .

ah:activityPeriod
    a owl:DatatypeProperty ;
    rdfs:label "periodo de la actividad"@es ;
    rdfs:domain ah:IngestionActivity ;
    rdfs:range xsd:gYear .

###############################################################################
# Perfiles de decisión y scoring                                             #
###############################################################################

ah:DecisionProfile
    a owl:Class ;
    rdfs:label "Perfil de decisión"@es .

ah:Score
    a owl:Class ;
    rdfs:label "Score"@es ;
    rdfs:subClassOf prov:Entity .

ah:ScoreContribution
    a owl:Class ;
    rdfs:label "Contribución al score"@es .

ah:hasScore
    a owl:ObjectProperty ;
    rdfs:label "tiene score"@es ;
    rdfs:domain ah:Territory ;
    rdfs:range ah:Score .

ah:forProfile
    a owl:ObjectProperty ;
    rdfs:label "para perfil"@es ;
    rdfs:domain ah:Score ;
    rdfs:range ah:DecisionProfile .

ah:hasContribution
    a owl:ObjectProperty ;
    rdfs:label "contribución"@es ;
    rdfs:domain ah:Score ;
    rdfs:range ah:ScoreContribution .

ah:weight
    a owl:DatatypeProperty ;
    rdfs:label "peso"@es ;
    rdfs:domain ah:ScoreContribution ;
    rdfs:range xsd:decimal .

ah:normalizedValue
    a owl:DatatypeProperty ;
    rdfs:label "valor normalizado"@es ;
    rdfs:domain ah:ScoreContribution ;
    rdfs:range xsd:decimal .

ah:impact
    a owl:DatatypeProperty ;
    rdfs:label "impacto"@es ;
    rdfs:domain ah:ScoreContribution ;
    rdfs:range xsd:decimal .

ah:scoreValue
    a owl:DatatypeProperty ;
    rdfs:label "valor del score"@es ;
    rdfs:domain ah:Score ;
    rdfs:range xsd:decimal .

ah:scoringVersion
    a owl:DatatypeProperty ;
    rdfs:label "versión del scoring"@es ;
    rdfs:domain ah:Score ;
    rdfs:range xsd:string .

ah:confidence
    a owl:DatatypeProperty ;
    rdfs:label "confianza"@es ;
    rdfs:domain ah:Score ;
    rdfs:range xsd:decimal .

###############################################################################
# Movilidad: flujos origen-destino (MITMA)                                   #
# Un MobilityFlow es una observación SOSA cuya "feature of interest" es la   #
# par origen-destino y cuyo "observed property" es el número de viajes en   #
# un periodo concreto. Se modela también como qb:Observation para integrarse #
# con cubos de datos por (origen, destino, periodo, modo).                  #
###############################################################################

ah:MobilityFlow
    a owl:Class ;
    rdfs:label "Flujo de movilidad"@es ;
    rdfs:comment "Volumen de desplazamientos entre dos territorios en un periodo (MITMA)."@es ;
    rdfs:subClassOf prov:Entity , sosa:Observation , qb:Observation .

ah:flowOrigin
    a owl:ObjectProperty ;
    rdfs:label "origen del flujo"@es ;
    rdfs:domain ah:MobilityFlow ;
    rdfs:range ah:Territory ;
    rdfs:subPropertyOf sosa:hasFeatureOfInterest .

ah:flowDestination
    a owl:ObjectProperty ;
    rdfs:label "destino del flujo"@es ;
    rdfs:domain ah:MobilityFlow ;
    rdfs:range ah:Territory .

ah:flowTrips
    a owl:DatatypeProperty ;
    rdfs:label "número de viajes"@es ;
    rdfs:comment "Cantidad de desplazamientos observados en el periodo."@es ;
    rdfs:domain ah:MobilityFlow ;
    rdfs:range xsd:decimal ;
    rdfs:subPropertyOf sosa:hasSimpleResult .

ah:flowMode
    a owl:DatatypeProperty ;
    rdfs:label "modo de transporte"@es ;
    rdfs:comment "Modo de transporte (por ejemplo 'all', 'car', 'public_transit')."@es ;
    rdfs:domain ah:MobilityFlow ;
    rdfs:range xsd:string .

ah:flowDistanceKm
    a owl:DatatypeProperty ;
    rdfs:label "distancia media (km)"@es ;
    rdfs:domain ah:MobilityFlow ;
    rdfs:range xsd:decimal .

###############################################################################
# Accidentes viales (DGT)                                                    #
# Un RoadAccident es una entidad PROV con geometría puntual y atributos de  #
# severidad. Se asocia opcionalmente al municipio que lo contiene para       #
# facilitar agregaciones administrativas.                                    #
###############################################################################

ah:RoadAccident
    a owl:Class ;
    rdfs:label "Accidente vial"@es ;
    rdfs:comment "Suceso registrado en la red viaria con localización y severidad (DGT)."@es ;
    rdfs:subClassOf prov:Entity , geo:Feature .

ah:accidentDate
    a owl:DatatypeProperty ;
    rdfs:label "fecha del accidente"@es ;
    rdfs:domain ah:RoadAccident ;
    rdfs:range xsd:date .

ah:accidentYear
    a owl:DatatypeProperty ;
    rdfs:label "año del accidente"@es ;
    rdfs:domain ah:RoadAccident ;
    rdfs:range xsd:gYear .

ah:accidentSeverity
    a owl:DatatypeProperty ;
    rdfs:label "severidad"@es ;
    rdfs:comment "'fatal', 'serious', 'slight'."@es ;
    rdfs:domain ah:RoadAccident ;
    rdfs:range xsd:string .

ah:accidentVictims
    a owl:DatatypeProperty ;
    rdfs:label "víctimas"@es ;
    rdfs:domain ah:RoadAccident ;
    rdfs:range xsd:integer .

ah:accidentFatalities
    a owl:DatatypeProperty ;
    rdfs:label "fallecidos"@es ;
    rdfs:domain ah:RoadAccident ;
    rdfs:range xsd:integer .

ah:accidentRoadType
    a owl:DatatypeProperty ;
    rdfs:label "tipo de vía"@es ;
    rdfs:domain ah:RoadAccident ;
    rdfs:range xsd:string .

ah:occursIn
    a owl:ObjectProperty ;
    rdfs:label "ocurre en"@es ;
    rdfs:comment "Territorio que contiene el accidente (resolución municipal por defecto)."@es ;
    rdfs:domain ah:RoadAccident ;
    rdfs:range ah:Territory .

###############################################################################
# Transporte público (CRTM y operadores compatibles GTFS)                    #
# TransitStop modela una parada con geometría puntual, TransitRoute una     #
# línea con identidad estable y modo. servesStop conecta rutas con paradas. #
###############################################################################

ah:TransitStop
    a owl:Class ;
    rdfs:label "Parada de transporte"@es ;
    rdfs:comment "Parada o estación de la red de transporte público (CRTM/GTFS)."@es ;
    rdfs:subClassOf geo:Feature .

ah:TransitRoute
    a owl:Class ;
    rdfs:label "Ruta de transporte"@es ;
    rdfs:comment "Línea o ruta de transporte público con identidad estable."@es .

ah:stopName
    a owl:DatatypeProperty ;
    rdfs:label "nombre de parada"@es ;
    rdfs:domain ah:TransitStop ;
    rdfs:range xsd:string .

ah:stopCode
    a owl:DatatypeProperty ;
    rdfs:label "código de parada"@es ;
    rdfs:domain ah:TransitStop ;
    rdfs:range xsd:string .

ah:routeShortName
    a owl:DatatypeProperty ;
    rdfs:label "nombre corto de ruta"@es ;
    rdfs:domain ah:TransitRoute ;
    rdfs:range xsd:string .

ah:routeLongName
    a owl:DatatypeProperty ;
    rdfs:label "nombre largo de ruta"@es ;
    rdfs:domain ah:TransitRoute ;
    rdfs:range xsd:string .

ah:transitMode
    a owl:DatatypeProperty ;
    rdfs:label "modo de transporte"@es ;
    rdfs:comment "'bus', 'metro', 'tram', 'rail', 'ferry'."@es ;
    rdfs:domain ah:TransitRoute ;
    rdfs:range xsd:string .

ah:operator
    a owl:DatatypeProperty ;
    rdfs:label "operador"@es ;
    rdfs:domain ah:TransitRoute ;
    rdfs:range xsd:string .

ah:locatedIn
    a owl:ObjectProperty ;
    rdfs:label "ubicada en"@es ;
    rdfs:comment "Territorio administrativo que contiene la parada."@es ;
    rdfs:domain ah:TransitStop ;
    rdfs:range ah:Territory .

ah:servesStop
    a owl:ObjectProperty ;
    rdfs:label "sirve a parada"@es ;
    rdfs:comment "Conecta una ruta con una parada por la que pasa."@es ;
    rdfs:domain ah:TransitRoute ;
    rdfs:range ah:TransitStop .
