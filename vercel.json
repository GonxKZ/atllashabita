{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix apps/web install --no-audit --no-fund --loglevel=error",
  "buildCommand": "npm --prefix apps/web run build",
  "outputDirectory": "apps/web/dist",
  "framework": "vite",
  "functions": {
    "api/index.py": {
      "maxDuration": 15,
      "includeFiles": "apps/api/src/**,data/seed/**,ontology/**",
      "excludeFiles": "{apps/api/tests/**,apps/web/**,docs/**,logs/**,.venv/**,**/__pycache__/**,**/.pytest_cache/**,**/.mypy_cache/**,**/.ruff_cache/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
